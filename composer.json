{
    "name": "trianity/laravel-pdf-viewer",
    "description": "A secure PDF.js based PDF viewer for Laravel, Livewire and Tailwind CSS.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Trianity\\LaravelPdfViewer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Trianity\\LaravelPdfViewer\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Trianity\\LaravelPdfViewer\\PdfViewerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
